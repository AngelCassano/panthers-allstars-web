<%- include('partials/head', { titulo }) %>
<%- include('partials/navbar') %>

<main class="page">
  <section class="section page-header">
    <p class="tag">Preparación Panthers</p>
    <h1>Entrenamientos</h1>
    <p>La preparación combina técnica, fuerza, flexibilidad, coreografía, limpieza de rutina, seguridad y mentalidad de competencia.</p>
  </section>

  <section class="section training-grid">
    <% entrenamientos.forEach(entrenamiento => { %>
      <article class="training-card">
        <div class="training-photo" style="background-image: url('<%= entrenamiento.imagen %>');"></div>
        <div>
          <span><%= entrenamiento.numero %></span>
          <h3><%= entrenamiento.titulo %></h3>
          <p><%= entrenamiento.descripcion %></p>
        </div>
      </article>
    <% }) %>
  </section>
</main>

<%- include('partials/footer') %>
