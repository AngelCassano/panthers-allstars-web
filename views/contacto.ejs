<%- include('partials/head', { titulo }) %>
<%- include('partials/navbar') %>

<main class="page">
  <section class="section page-header">
    <p class="tag">Contacto</p>
    <h1>Conecta con Club Panthers All Stars</h1>
    <p>Sección preparada para Instagram oficial, formulario de inscripción, comuna, horarios y datos de contacto que confirmen los dueños.</p>
  </section>

  <section class="section contact-grid">
    <article class="contact-card">
      <h2>Instagram oficial</h2>
      <p>Referencia principal entregada por el club.</p>
      <a href="https://www.instagram.com/club_panthers_allstars/" target="_blank" rel="noreferrer" class="btn btn-primary">Abrir Instagram</a>
    </article>
    <article class="contact-card">
      <h2>Inscripción</h2>
      <p>Los interesados pueden completar el formulario y el club revisa las postulaciones desde el panel administrador.</p>
      <a href="/inscripcion" class="btn btn-outline">Ir al formulario</a>
    </article>
    <article class="contact-card contact-logo-card">
      <h2>San Bernardo</h2>
      <img src="/img/san-bernardo.png" alt="Logo San Bernardo" />
      <p>Comuna de Santiago de Chile. Dirección exacta, WhatsApp y correo quedan pendientes para confirmar.</p>
    </article>
  </section>

  <section class="section split compact">
    <div class="banner-card full-card">
      <img src="/img/logo-panthers.png" alt="Logo Panthers" />
      <div>
        <h3>Club Panthers All Stars</h3>
        <p>Instagram: @club_panthers_allstars</p>
      </div>
    </div>
    <div class="highlight-box">
      <p class="tag">Datos pendientes</p>
      <h2>Para dejarla 100% real</h2>
      <p>Falta confirmar WhatsApp, correo, dirección exacta, horarios de entrenamiento y formulario final que usarán los dueños del club.</p>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
